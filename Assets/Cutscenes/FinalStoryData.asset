%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3be7d24fc03af1a42a06d1fa2e5941a6, type: 3}
  m_Name: FinalStoryData
  m_EditorClassIdentifier: Assembly-CSharp::StoryData
  steps:
  - image: {fileID: 7141547621344835472, guid: 60e4a1d09e103dc4283831a841ddf8a8, type: 3}
    text: "Depois de tanta matan\xE7a, finalmente l\xE1 estava ela, o santo graal,
      protegia por um vidro a prova de bala"
  - image: {fileID: 7141547621344835472, guid: 60e4a1d09e103dc4283831a841ddf8a8, type: 3}
    text: "Mas n\xE3o a prova de um homem sonhador"
  - image: {fileID: 7141547621344835472, guid: 60e4a1d09e103dc4283831a841ddf8a8, type: 3}
    text: "Com um cute ele quebra o vidro, pois nada iria separar ele da H200R, e
      por l\xE1 ele fica quase um minuto em choque sem acreditar que estava logo
      em sua frente"
  - image: {fileID: 7141547621344835472, guid: 60e4a1d09e103dc4283831a841ddf8a8, type: 3}
    text: "Depois de agradecer aos Deuses pela ben\xE7\xE3o, ele sobe e realiza o
      seu sonho"
  - image: {fileID: 6677204606081336718, guid: e776859c2f976204fb8c3f54026a0d52, type: 3}
    text: "Por\xE9m sua paz dura pouco pois uma caixa de som come\xE7a a falar"
  - image: {fileID: 6677204606081336718, guid: e776859c2f976204fb8c3f54026a0d52, type: 3}
    text: "Parab\xE9ns, voc\xEA foi o ganhador do epis\xF3dio, o premio \xE9 todo
      seu\u201D"
  - image: {fileID: 6677204606081336718, guid: e776859c2f976204fb8c3f54026a0d52, type: 3}
    text: "O dispositivo em seu peito foi desativado e n\xE3o oferece mais risco
      a sua vida, aproveite seu trof\xE9u"
  - image: {fileID: 6677204606081336718, guid: e776859c2f976204fb8c3f54026a0d52, type: 3}
    text: "O pr\xE9dio vai explodir em 20 segundos, o show \xE9 um oferecimento\u2026"
  - image: {fileID: 509165996699816679, guid: ddcf9cc7fd4fccc49a1e2fb707333907, type: 3}
    text: "Marcos logo ligou e j\xE1 acelerou sua moto, pois ele n\xE3o podia perder
      sua H200R e sua vida, que agora fazia sentido ele viver pois tinha que aproveitar
      a vida de Deus que o esperava no futuro"
  - image: {fileID: 509165996699816679, guid: ddcf9cc7fd4fccc49a1e2fb707333907, type: 3}
    text: "Quando o contador chegou em 7 alcan\xE7ou uma janela do pr\xE9dio e de
      l\xE1 se jogou para sua liberdade\u201D"
  - image: {fileID: 1764589202971507330, guid: 74fa698aebba2bd43a97a208f80edded, type: 3}
    text: "Quando Marcos rompeu a janela e saltou para o vazio, j\xE1 n\xE3o era
      apenas um homem fugindo de um pr\xE9dio em chamas. Depois de atravessar cada
      andar, cada luta e cada ferida, ele se tornou outra coisa"
  - image: {fileID: 1764589202971507330, guid: 74fa698aebba2bd43a97a208f80edded, type: 3}
    text: "No meio da noite, com a explos\xE3o rasgando o c\xE9u atr\xE1s dele e
      os estilha\xE7os dan\xE7ando ao redor, Marcos voava sobre sua moto como se
      estivesse descendo de um lugar sagrado, levando no corpo as marcas da guerra
      e no olhar a calma de quem finalmente chegou ao fim da pr\xF3pria jornada"
  - image: {fileID: 1764589202971507330, guid: 74fa698aebba2bd43a97a208f80edded, type: 3}
    text: "N\xE3o parecia uma queda n\xE3o parecia uma fuga"
  - image: {fileID: 1764589202971507330, guid: 74fa698aebba2bd43a97a208f80edded, type: 3}
    text: Parecia julgamento parecia liberdade
  - image: {fileID: 1764589202971507330, guid: 74fa698aebba2bd43a97a208f80edded, type: 3}
    text: "Parecia o instante em que um mortal, guiado pela velocidade e pela obsess\xE3o,
      abandona a terra por um segundo e vira lenda"
  - image: {fileID: 1764589202971507330, guid: 74fa698aebba2bd43a97a208f80edded, type: 3}
    text: "Ali, no meio do fogo e da destrui\xE7\xE3o, Marcos n\xE3o era um homem
      sobre uma moto caindo do c\xE9u. Era um anjo da velocidade, jogando sua gra\xE7a
      sobre o mundo"
